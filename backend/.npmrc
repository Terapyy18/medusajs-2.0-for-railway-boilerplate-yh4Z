# Allow pnpm to hoist Medusa admin packages so they are resolvable by Vite
# during the admin extension (frontend) build.
# Without this, pnpm's strict isolation prevents @medusajs/ui, @medusajs/icons, etc.
# from being found in node_modules even though they're listed as rollup externals.
public-hoist-pattern[]=@medusajs/*
public-hoist-pattern[]=@tanstack/*
public-hoist-pattern[]=react-router-dom
